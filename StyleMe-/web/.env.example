# Optional: enable “Save session” (anonymous auth + Storage + style_sessions table)
# 1. Copy this file to .env in this same folder (web/)
# 2. Paste Project URL + anon public key from Supabase → Settings → API
# 3. The anon key is a long JWT (starts with eyJ…), not a short label
# 4. Restart npm run dev (Vite reads .env only at startup)
# 5. Enable Anonymous sign-ins in Authentication → Providers
# 6. Run SQL in web/supabase/migrations/001_styleme.sql in the Supabase SQL editor

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt

# Optional: POST multipart (field "photo" + "context" JSON). Response: { "images": ["https://..."] } or { "urls": [...] }.
# This repo includes an Edge Function at web/supabase/functions/hair-preview/index.ts.
# Deploy it and store OPENAI_API_KEY + SUPABASE_SERVICE_ROLE_KEY as Supabase Function secrets.
# Restart dev after changes.
# VITE_HAIR_PREVIEW_API_URL=https://your-project.supabase.co/functions/v1/hair-preview

# Face shape (default mode) is local in the browser (suggested guess + manual pick).
# No Gemini face-shape key is required for the normal flow.
# Optional advanced integration (not required for demos):
# - web/src/lib/faceShapeVision.ts
# - web/supabase/functions/face-shape/index.ts
# If you enable that path later, you can define:
# VITE_FACE_SHAPE_API_URL=https://your-project.supabase.co/functions/v1/face-shape
